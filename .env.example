# MySQL connection string, e.g. mysql://user:password@host:3306/dbname
DATABASE_URL=

# Secret used to sign admin session tokens. Use a long random string.
JWT_SECRET=

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# SMTP settings for sending contact form email notifications.
# Example values shown are for Gmail SMTP (requires an app password, not your regular password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where contact form notifications should be sent
CONTACT_NOTIFY_EMAIL=faizankhanyahoou@gmail.com
